# Copy to `supabase/.env` for local Edge secrets (never commit real values).
# Also set the same vars in Supabase Dashboard → Edge Functions → Secrets.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# QR signing (HS256). Prefer QR_JWT_SECRET or SUPABASE1_JWT_SECRET if dashboard blocks SUPABASE_JWT_SECRET (manual names take precedence in code).
# QR_JWT_SECRET=your_shared_secret_for_qr_only
# SUPABASE1_JWT_SECRET=alternative_name
SUPABASE_JWT_SECRET=your_jwt_signing_secret

UNIFONIC_API_KEY=your_unifonic_bearer_token
FCM_SERVER_KEY=your_fcm_legacy_or_v1_placeholder

# Optional: require on `scheduled-notifications` when not using service role in cron HTTP call
CRON_SECRET=generate_a_long_random_string
